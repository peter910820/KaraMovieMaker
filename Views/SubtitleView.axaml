<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaraMovieMaker.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="KaraMovieMaker.Views.SubtitleView"
             x:DataType="vm:SubtitleViewModel">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="{Binding Title}" HorizontalAlignment="Center" FontSize="20"/>
        <TextBlock Text="{Binding Description}" HorizontalAlignment="Center" Opacity="0.7"/>
    </StackPanel>

</UserControl>
